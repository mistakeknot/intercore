{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intercore.dev/contracts/events/review-event.json",
  "properties": {
    "id": {
      "type": "integer"
    },
    "run_id": {
      "type": "string"
    },
    "finding_id": {
      "type": "string"
    },
    "agents_json": {
      "type": "string"
    },
    "resolution": {
      "type": "string"
    },
    "dismissal_reason": {
      "type": "string"
    },
    "chosen_severity": {
      "type": "string"
    },
    "impact": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "project_dir": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false,
  "type": "object",
  "required": [
    "id",
    "finding_id",
    "agents_json",
    "resolution",
    "chosen_severity",
    "impact",
    "timestamp"
  ]
}
