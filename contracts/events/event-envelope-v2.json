{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intercore.dev/contracts/events/event-envelope-v2.json",
  "properties": {
    "version": {
      "type": "integer",
      "enum": [
        1,
        2
      ]
    },
    "trace_id": {
      "type": "string"
    },
    "span_id": {
      "type": "string"
    },
    "parent_span_id": {
      "type": "string"
    },
    "caller_identity": {
      "type": "string"
    },
    "payload_type": {
      "type": "string",
      "enum": [
        "phase",
        "dispatch",
        "coordination",
        "legacy"
      ]
    },
    "payload": true
  },
  "additionalProperties": false,
  "type": "object"
}
